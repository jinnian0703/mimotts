APP_NAME=MimoTTS
APP_ENV=production
APP_KEY=replace_with_generated_laravel_app_key
APP_DEBUG=false
APP_URL=https://mimo.example.com
FRONTEND_URL=https://mimo.example.com

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mimo
DB_USERNAME=mimo
DB_PASSWORD=replace_with_database_password

CACHE_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=mimo.example.com
CORS_ALLOWED_ORIGINS=https://mimo.example.com
FILESYSTEM_DISK=local

LINUXDO_CLIENT_ID=replace_with_linuxdo_client_id
LINUXDO_CLIENT_SECRET=replace_with_linuxdo_client_secret
LINUXDO_REDIRECT_URI=https://mimo.example.com/api.php?r=/auth/linuxdo/callback

MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_API_KEY=replace_with_default_mimo_api_key
MIMO_TIMEOUT=120

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=MimoTTS

MIMO_DEPLOYMENT_MODE=source
MIMO_UPDATE_REPOSITORY=jinnian0703/mimotts
MIMO_UPDATE_DOCKER_IMAGE=ghcr.io/jinnian0703/mimotts
MIMO_UPDATE_MANIFEST_URL=
MIMO_UPDATE_ALLOW_UPGRADE=false

UPLOAD_MAX_SIZE=100M
PHP_UPLOAD_MAX_FILESIZE=100M
PHP_POST_MAX_SIZE=100M
