# Docker Compose 项目名。请保持稳定，避免升级后数据卷名称变化。
COMPOSE_PROJECT_NAME=mimo

# Web 访问端口。访问地址通常是 http://服务器IP:WEB_PORT。
WEB_PORT=18081

# 应用镜像。生产环境建议改成固定版本号，例如 ghcr.io/jinnian0703/mimotts:v1.0.0.5。
MIMO_IMAGE=ghcr.io/jinnian0703/mimotts:latest

# 更新检测配置。默认只生成升级命令，不允许 Web 后台直接执行 Docker 升级。
MIMO_DEPLOYMENT_MODE=docker
MIMO_UPDATE_REPOSITORY=jinnian0703/mimotts
MIMO_UPDATE_DOCKER_IMAGE=ghcr.io/jinnian0703/mimotts
MIMO_UPDATE_MANIFEST_URL=
MIMO_UPDATE_ALLOW_UPGRADE=false

# 站点基础信息。部署到公网后请把 localhost 改成域名或服务器 IP。
APP_NAME=MimoTTS
APP_ENV=production
APP_KEY=replace_with_generated_laravel_app_key
APP_DEBUG=false
APP_URL=http://localhost:18081
FRONTEND_URL=http://localhost:18081
PUBLIC_API_BASE_URL=/api

# 日志配置。排查问题时可临时把 LOG_LEVEL 改为 debug。
LOG_CHANNEL=stack
LOG_LEVEL=info

# 数据库配置。Docker 默认使用 SQLite，数据库文件保存在 app_storage 数据卷中。
# 单机部署优先推荐 SQLite，不需要额外维护 MySQL/MariaDB 容器。
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/backend/storage/database.sqlite
DB_FOREIGN_KEYS=true

# 运行时存储配置。默认使用文件缓存、文件会话和同步队列，无需额外队列进程。
CACHE_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=localhost:18081,127.0.0.1:18081
CORS_ALLOWED_ORIGINS=http://localhost:18081,http://127.0.0.1:18081
FILESYSTEM_DISK=local

# 容器启动行为。
# RUN_MIGRATIONS=true 会在每次启动时自动执行数据库迁移。
# MIMO_DOCKER_AUTO_INSTALL=true 会在首次启动时自动创建管理员，并同步本文件中的登录/API 配置。
# MIMO_DOCKER_SYNC_CONFIG=true 会在重启时继续把本文件中的登录/API 配置同步到系统设置。
RUN_MIGRATIONS=true
MIMO_DOCKER_AUTO_INSTALL=true
MIMO_DOCKER_SYNC_CONFIG=true

# 首次管理员账号。
# MIMO_ADMIN_PASSWORD 留空时会自动生成随机密码，并写入 docker compose logs app。
# 系统安装完成后，重启容器不会重新生成或覆盖管理员。
MIMO_ADMIN_NAME=MimoTTS Admin
MIMO_ADMIN_EMAIL=admin@mimotts.local
MIMO_ADMIN_PASSWORD=

# 邮箱账号登录开关。
# 管理员邮箱密码登录始终可用；EMAIL_LOGIN_ENABLED 只控制普通用户邮箱登录入口。
EMAIL_LOGIN_ENABLED=true
EMAIL_REGISTRATION_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=false

# LinuxDo Connect。Client ID/Secret 为空时，前台不会显示 LinuxDo 登录入口。
LINUXDO_LOGIN_ENABLED=true
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=
LINUXDO_REDIRECT_URI=http://localhost:18081/api/auth/linuxdo/callback

# Xiaomi MiMo API。填写 MIMO_API_KEY 后，系统级语音任务可直接使用。
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_API_KEY=
MIMO_TIMEOUT=120

# SMTP 发信配置。只有开启邮箱验证、两步验证或需要邮件通知时才必须填写。
MAIL_MAILER=smtp
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=MimoTTS

# 可选邮件 API 配置。不使用 SMTP 时，可设置 MAIL_DRIVER=api 并填写以下字段。
MAIL_API_PROVIDER=generic_json
MAIL_API_ENDPOINT=
MAIL_API_TOKEN=

# PHP 上传限制。需要上传更大文件时，同时调整这三个值。
UPLOAD_MAX_SIZE=100M
PHP_UPLOAD_MAX_FILESIZE=100M
PHP_POST_MAX_SIZE=100M
