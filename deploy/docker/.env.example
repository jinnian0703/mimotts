COMPOSE_PROJECT_NAME=mimo

WEB_PORT=18081

APP_NAME=Mimo
APP_ENV=production
APP_KEY=replace_with_generated_laravel_app_key
APP_DEBUG=false
APP_URL=http://localhost:18081
FRONTEND_URL=http://localhost:18081
PUBLIC_API_BASE_URL=/api

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/backend/storage/database.sqlite
DB_FOREIGN_KEYS=true

CACHE_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=localhost:18081,127.0.0.1:18081
CORS_ALLOWED_ORIGINS=http://localhost:18081,http://127.0.0.1:18081
FILESYSTEM_DISK=local
RUN_MIGRATIONS=true

LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=
LINUXDO_REDIRECT_URI=http://localhost:18081/api/auth/linuxdo/callback

MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_API_KEY=
MIMO_TIMEOUT=120

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Mimo

UPLOAD_MAX_SIZE=100M
PHP_UPLOAD_MAX_FILESIZE=100M
PHP_POST_MAX_SIZE=100M
